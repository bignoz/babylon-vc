{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(favicon-32x32.png|favicon-192x192.png|apple-touch-icon.png|favicon.ico|og-image.png|og-image.jpg|babylon-logo.png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
